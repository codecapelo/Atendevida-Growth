{
  "name": "atendevida-growth",
  "version": "0.1.0",
  "description": "Automação de marketing e tráfego pago para a plataforma de telemedicina Atendevida",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "lint": "eslint src tests scripts",
    "format": "prettier --write src tests scripts",
    "seed": "node scripts/seed-posts.js",
    "test:meta-token": "node scripts/test-meta-token.js",
    "hash-password": "node scripts/hash-password.js"
  },
  "imports": {
    "#config/*": "./src/config/*",
    "#lib/*": "./src/lib/*",
    "#services/*": "./src/services/*",
    "#jobs/*": "./src/jobs/*",
    "#routes/*": "./src/routes/*",
    "#middleware/*": "./src/middleware/*"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@supabase/supabase-js": "^2.49.4",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.3",
    "cookie-session": "^2.1.1",
    "dotenv": "^16.5.0",
    "ejs": "^5.0.2",
    "express": "^4.21.2",
    "express-ejs-layouts": "^2.5.1",
    "googleapis": "^171.4.0",
    "node-cron": "^3.0.3",
    "openai": "^4.96.0",
    "pino": "^9.7.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.1.3",
    "eslint": "^9.25.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3",
    "vitest": "^3.1.3"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

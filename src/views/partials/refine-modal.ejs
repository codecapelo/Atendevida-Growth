<div
  x-show="refineOpen"
  x-cloak
  @keydown.escape.window="refineOpen = false"
  class="fixed inset-0 z-40 flex items-center justify-center bg-slate-900/40 backdrop-blur-sm p-4"
  style="display: none;"
>
  <div class="bg-white rounded-xl shadow-xl max-w-5xl w-full max-h-[90vh] flex flex-col">
    <div class="px-5 py-3 border-b border-slate-200 flex items-center justify-between">
      <div>
        <h3 class="font-semibold text-slate-900 text-sm">Refinar com IA</h3>
        <p class="text-xs text-slate-500">Compare e escolha o que usar.</p>
      </div>
      <button type="button" @click="refineOpen = false" class="text-slate-400 hover:text-slate-700">✕</button>
    </div>

    <div class="flex-1 overflow-y-auto p-5">
      <div x-show="refineLoading" class="text-center py-12 text-sm text-slate-500">Chamando o modelo… isso pode levar até 30s.</div>
      <div x-show="refineError" class="rounded-md border border-rose-200 bg-rose-50 text-rose-700 text-sm px-3 py-2 mb-3" x-text="refineError"></div>
      <div x-show="!refineLoading && !refineError && refineResult" class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-2">Atual</div>
          <div class="bg-slate-50 border border-slate-200 rounded-lg p-3 text-sm whitespace-pre-wrap" x-text="form.copy_principal"></div>
          <div class="mt-2 text-xs text-sky-700" x-text="(form.hashtags || []).join(' ')"></div>
        </div>
        <div>
          <div class="text-xs font-semibold text-brand-700 uppercase tracking-wide mb-2">Refinado</div>
          <div class="bg-brand-50 border border-brand-200 rounded-lg p-3 text-sm whitespace-pre-wrap" x-text="refineResult?.caption"></div>
          <div class="mt-2 text-xs text-sky-700" x-text="(refineResult?.hashtags || []).join(' ')"></div>
        </div>
      </div>
    </div>

    <div class="px-5 py-3 border-t border-slate-200 flex items-center justify-end gap-2">
      <button type="button" @click="refineOpen = false" class="rounded-lg border border-slate-200 text-slate-600 text-sm px-3 py-1.5 hover:bg-slate-50">Fechar</button>
      <button type="button" @click="useRefined()" :disabled="!refineResult" class="rounded-lg bg-brand-600 hover:bg-brand-700 disabled:opacity-50 text-white text-sm font-medium px-3 py-1.5">Usar refinado</button>
    </div>
  </div>
</div>

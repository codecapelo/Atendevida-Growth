<aside class="w-60 bg-slate-900 text-slate-200 flex flex-col flex-shrink-0">
  <div class="px-5 py-5 border-b border-slate-800">
    <a href="/dashboard" class="flex items-center gap-2">
      <span class="w-8 h-8 rounded-lg bg-brand-500 flex items-center justify-center text-white font-bold">A</span>
      <div class="leading-tight">
        <div class="font-semibold text-white text-sm">Atendevida</div>
        <div class="text-xs text-slate-400">Growth Studio</div>
      </div>
    </a>
  </div>
  <nav class="flex-1 px-3 py-4 space-y-1 text-sm">
    <%
      const items = [
        { key: 'home', href: '/dashboard', label: 'Visão geral', icon: '◧' },
        { key: 'calendar', href: '/dashboard/calendar', label: 'Calendário', icon: '▦' },
        { key: 'posts', href: '/dashboard/posts', label: 'Posts', icon: '✦' },
        { key: 'new', href: '/dashboard/posts/new', label: 'Novo post', icon: '+' },
        { key: 'metrics', href: '/dashboard/metrics', label: 'Métricas', icon: '↗' },
      ];
    %>
    <% items.forEach(function(it) { %>
      <a
        href="<%= it.href %>"
        class="flex items-center gap-3 px-3 py-2 rounded-md transition <%= active === it.key ? 'bg-slate-800 text-white' : 'text-slate-300 hover:bg-slate-800 hover:text-white' %>"
      >
        <span class="w-5 text-center text-slate-400"><%= it.icon %></span>
        <span><%= it.label %></span>
      </a>
    <% }); %>
  </nav>
  <div class="px-5 py-4 border-t border-slate-800 text-xs text-slate-500">
    v0.1 · <%= new Date().getFullYear() %>
  </div>
</aside>

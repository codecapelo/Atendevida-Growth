    casos_comuns:      { label: 'Casos comuns',       cls: 'bg-cyan-50 text-cyan-700 border-cyan-200' },
    bastidores:        { label: 'Bastidores',         cls: 'bg-violet-50 text-violet-700 border-violet-200' },
    mitos:             { label: 'Mitos',              cls: 'bg-fuchsia-50 text-fuchsia-700 border-fuchsia-200' },
    renovacao_receita: { label: 'Renovação receita',  cls: 'bg-teal-50 text-teal-700 border-teal-200' },
  };
  const p = pilarMap[pilar] || { label: pilar, cls: 'bg-slate-50 text-slate-700 border-slate-200' };
